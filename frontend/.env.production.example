# Host do site principal (landing). Qualquer outro host = subdomínio ou domínio customizado. Ver docs/DOMINIO-TENANT-RESOLUCAO.md.
NEXT_PUBLIC_APP_HOST=app.cardapio.nexoracloud.com.br
# URL completa do app (link "Ir para o site principal" na tela de domínio não encontrado)
NEXT_PUBLIC_APP_URL=https://app.cardapio.nexoracloud.com.br
NEXT_PUBLIC_API_URL=https://api.cardapio.nexoracloud.com.br/api
NEXT_PUBLIC_ADMIN_URL=https://admin.cardapio.nexoracloud.com.br
# Host base do menu (ex.: menu.cardapio.nexoracloud.com.br). Quando o visitante acessa esse host exato,
# mostra a página premium em vez de DomainNotFound. Deixe vazio para não usar.
# NEXT_PUBLIC_MENU_BASE_HOST=menu.cardapio.nexoracloud.com.br
# Slug da loja para /menu e /product (opcional; pode usar ?store=slug na URL)
# NEXT_PUBLIC_STORE_SLUG=minha-loja

# WhatsApp comercial (NEXORA): número com DDI, ex. 5511999999999. Usado nos CTAs "Falar no WhatsApp" da landing e /planos.
# NEXT_PUBLIC_WHATSAPP_COMERCIAL=5511999999999
