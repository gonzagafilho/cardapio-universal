# App
NODE_ENV=development
PORT=3000
API_PREFIX=api

# SaaS / Produção (domínio externo)
# API pública (usado por admin e frontend nas variáveis NEXT_PUBLIC_API_URL)
# PUBLIC_API_URL=https://api.cardapio.nexoracloud.com.br
# CORS: origens permitidas (separadas por vírgula). Vazio = permite todas.
# CORS_ORIGINS=https://admin.cardapio.nexoracloud.com.br,https://app.cardapio.nexoracloud.com.br
# Resolução por subdomínio: empresa.cardapio.app → slug "empresa". Domínio base (sem subdomínio), ex.: cardapio.app. Ver docs/DOMINIO-TENANT-RESOLUCAO.md.
# SUBDOMAIN_BASE_DOMAIN=cardapio.app
# URL do app público (cardápio). Usado no onboarding para retornar publicCardUrl na resposta.
# APP_PUBLIC_URL=https://app.cardapio.nexoracloud.com.br

# Database
DATABASE_URL="postgresql://user:password@localhost:5432/cardapio_universal?schema=public"

# Redis (opcional: cache e filas; se vazio, cache em memória e sem Bull)
# REDIS_URL=redis://localhost:6379
# REDIS_CACHE_TTL=300

# JWT
JWT_SECRET=your-super-secret-key-change-in-production
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your-refresh-secret-key
JWT_REFRESH_EXPIRES_IN=30d

# Upload
UPLOAD_MAX_FILE_SIZE=5242880
UPLOAD_ALLOWED_MIME_TYPES=image/jpeg,image/png,image/webp,image/gif

# Mercado Pago (assinaturas recorrentes)
# Se MERCADOPAGO_ACCESS_TOKEN estiver vazio, o checkout com MP fica desabilitado.
# MERCADOPAGO_ACCESS_TOKEN=APP_USR-xxxx
# MERCADOPAGO_WEBHOOK_SECRET=opcional-para-validar-x-signature
# URL para onde o usuário volta após pagar no MP (ex.: painel admin /billing)
# BILLING_BACK_URL=https://admin.cardapio.nexoracloud.com.br/billing
# Valores em BRL por plano (opcional; padrão: basic 29.90, pro 79.90, enterprise 199.90)
# MERCADOPAGO_PLAN_AMOUNT_BASIC=29.90
# MERCADOPAGO_PLAN_AMOUNT_PRO=79.90
# MERCADOPAGO_PLAN_AMOUNT_ENTERPRISE=199.90
# Notificações de pagamento PIX (webhook). Ex.: https://api.xxx.com/api/payments/webhooks/mercadopago
# MERCADOPAGO_PAYMENT_NOTIFICATION_URL=https://api.cardapio.nexoracloud.com.br/api/payments/webhooks/mercadopago
